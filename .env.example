# Copy to .env and fill in. .env is gitignored.

# Google OAuth2 client credentials from GCP Console.
# APIs & Services → Credentials → Your Desktop app client "grace".
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Optional daemon overrides (defaults are fine).
# GRACE_HOST=127.0.0.1
# GRACE_PORT=3535
# GRACE_DATA_DIR=~/.grace
